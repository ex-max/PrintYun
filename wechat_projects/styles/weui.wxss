/* WeUI 样式库 - 基础组件样式 */

/* 按钮 */
.weui-btn {
  position: relative;
  display: block;
  width: 100%;
  padding: 24rpx 32rpx;
  font-size: 34rpx;
  line-height: 1.4;
  text-align: center;
  border-radius: 12rpx;
  box-sizing: border-box;
  text-decoration: none;
  overflow: hidden;
}

.weui-btn_primary {
  background-color: #07C160;
  color: #FFFFFF;
}

.weui-btn_default {
  background-color: #F7F7F7;
  color: #000000;
}

.weui-btn_warn {
  background-color: #FA5151;
  color: #FFFFFF;
}

.weui-btn[disabled] {
  opacity: 0.6;
}

/* 单元格 */
.weui-cells {
  margin-top: 24rpx;
  background-color: #FFFFFF;
  line-height: 1.4;
  font-size: 34rpx;
  overflow: hidden;
  position: relative;
}

.weui-cell {
  padding: 24rpx 32rpx;
  position: relative;
  display: flex;
  align-items: center;
}

.weui-cell__bd {
  flex: 1;
}

.weui-cell__ft {
  text-align: right;
  color: #999999;
}

/* 表单 */
.weui-input {
  width: 100%;
  border: 0;
  outline: 0;
  background-color: transparent;
  font-size: inherit;
  color: inherit;
  height: 1.4em;
  line-height: 1.4;
}

/* 加载更多 */
.weui-loadmore {
  width: 65%;
  margin: 32rpx auto;
  text-align: center;
  font-size: 28rpx;
}

.weui-loadmore__tips {
  display: inline-block;
  vertical-align: middle;
  color: #888888;
}

/* 徽章 */
.weui-badge {
  display: inline-block;
  padding: 4rpx 12rpx;
  font-size: 24rpx;
  line-height: 1;
  color: #FFFFFF;
  background-color: #FA5151;
  border-radius: 28rpx;
}

/* 提示框 */
.weui-toast {
  position: fixed;
  z-index: 5000;
  width: 152rpx;
  min-height: 152rpx;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(17, 17, 17, 0.7);
  text-align: center;
  border-radius: 24rpx;
  color: #FFFFFF;
}

/* 消息页 */
.weui-msg {
  padding-top: 96rpx;
  text-align: center;
}

.weui-msg__icon-area {
  margin-bottom: 48rpx;
}

.weui-msg__title {
  font-size: 40rpx;
  font-weight: 500;
  color: #000000;
  margin-bottom: 16rpx;
}

.weui-msg__desc {
  font-size: 28rpx;
  color: #888888;
}

/* 进度条 */
.weui-progress {
  display: flex;
  align-items: center;
}

.weui-progress__bar {
  flex: 1;
  background-color: #EBEBEB;
  height: 6rpx;
  border-radius: 6rpx;
  overflow: hidden;
}

.weui-progress__inner-bar {
  width: 0;
  height: 100%;
  background-color: #07C160;
}

/* 搜索栏 */
.weui-search-bar {
  position: relative;
  padding: 16rpx;
  background-color: #EFEFF4;
  display: flex;
  box-sizing: border-box;
  align-items: center;
}

.weui-search-bar__box {
  position: relative;
  flex: 1;
  background-color: #FFFFFF;
  border-radius: 8rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
}

/* 面板 */
.weui-panel {
  background-color: #FFFFFF;
  margin-top: 20rpx;
  position: relative;
  overflow: hidden;
}

.weui-panel__hd {
  padding: 28rpx 32rpx 20rpx;
  color: #999999;
  font-size: 28rpx;
  position: relative;
}

.weui-panel__bd {
  position: relative;
}

/* 媒体框 */
.weui-media-box {
  padding: 24rpx;
  position: relative;
}

.weui-media-box__title {
  font-weight: 400;
  font-size: 34rpx;
  color: #000000;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding-right: 8rpx;
}

.weui-media-box__desc {
  color: #999999;
  font-size: 26rpx;
  line-height: 1.2;
  padding-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

/* 文章 */
.weui-article {
  padding: 40rpx 32rpx;
  font-size: 34rpx;
}

.weui-article__h1 {
  font-size: 44rpx;
  font-weight: 500;
  margin-bottom: 32rpx;
}

.weui-article__h2 {
  font-size: 40rpx;
  font-weight: 500;
  margin-bottom: 24rpx;
  margin-top: 32rpx;
}

.weui-article__h3 {
  font-size: 36rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
  margin-top: 24rpx;
}

.weui-article__p {
  margin: 0 0 24rpx;
  line-height: 1.6;
}
