<!--pages/pay/success.wxml-->
<view class="container">
  <!-- 成功图标 -->
  <view class="success-icon-wrap">
    <image class="success-icon" src="/assets/icons/success.png"></image>
  </view>
  
  <view class="success-text">支付成功</view>
  <view class="success-hint">订单已提交打印，请到店取件</view>

  <!-- 取件码 -->
  <view class="pickup-code card">
    <view class="code-label">取件码</view>
    <view class="code-value">{{tradeNumber}}</view>
    <view class="code-tip">到店后请出示此取件码</view>
  </view>

  <!-- 订单信息 -->
  <view class="order-info card">
    <view class="info-row">
      <text class="info-label">订单号</text>
      <text class="info-value">{{orderInfo.tradeNumber}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">文件名</text>
      <text class="info-value">{{orderInfo.fileName}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">打印点</text>
      <text class="info-value">{{orderInfo.printPlaceName}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">支付金额</text>
      <text class="info-value price">¥{{orderInfo.amount}}</text>
    </view>
  </view>

  <!-- 打印点地址 -->
  <view class="print-place card" wx:if="{{printPlace}}">
    <view class="place-header">
      <image class="place-icon" src="/assets/icons/location.png"></image>
      <text class="place-title">{{printPlace.name}}</text>
    </view>
    <view class="place-address">{{printPlace.address}}</view>
    <view class="place-actions">
      <button class="btn-nav" bindtap="openLocation">
        <image class="nav-icon" src="/assets/icons/navigation.png"></image>
        导航前往
      </button>
      <button class="btn-phone" bindtap="makePhoneCall" wx:if="{{printPlace.phone}}">
        <image class="phone-icon" src="/assets/icons/phone.png"></image>
        联系电话
      </button>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-buttons">
    <button class="btn-order" bindtap="goToOrderDetail">查看订单</button>
    <button class="btn-home" bindtap="goHome">返回首页</button>
  </view>
</view>
