/* pages/pay/pay.wxss */

.container {
  padding: 30rpx;
  padding-bottom: 400rpx;
  background: #F5F5F5;
  min-height: 100vh;
}

/* 订单信息 */
.order-info {
  margin-bottom: 20rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 24rpx;
  margin-bottom: 24rpx;
  border-bottom: 1rpx solid #E5E5E5;
}

.order-number {
  font-size: 28rpx;
  color: #666666;
}

.order-status {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
}

.status-pending {
  background: #FFF7E6;
  color: #FA8C16;
}

.order-detail {
  
}

.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 28rpx;
}

.detail-label {
  color: #999999;
  width: 140rpx;
  flex-shrink: 0;
}

.detail-value {
  color: #333333;
  text-align: right;
  flex: 1;
}

/* 金额卡片 */
.amount-card {
  text-align: center;
  padding: 50rpx 30rpx;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #6BA8E8 100%);
}

.amount-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 16rpx;
}

.amount-value {
  color: #FFFFFF;
  margin-bottom: 16rpx;
}

.amount-currency {
  font-size: 36rpx;
}

.amount-number {
  font-size: 72rpx;
  font-weight: 700;
}

.amount-detail {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 倒计时 */
.countdown-card {
  padding: 24rpx 30rpx;
  margin-bottom: 20rpx;
}

.countdown-text {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #FF4D4F;
}

.countdown-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

/* 支付按钮 */
.pay-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 30rpx;
  background: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.btn-pay {
  background: #07C160;
  color: #FFFFFF;
  font-size: 34rpx;
  padding: 28rpx;
  border-radius: 12rpx;
  border: none;
  margin: 0;
  margin-bottom: 20rpx;
  line-height: normal;
}

.btn-pay::after {
  border: none;
}

.btn-pay[disabled] {
  background: #CCCCCC;
}

.btn-cancel {
  background: #FFFFFF;
  color: #999999;
  font-size: 28rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  border: 1rpx solid #E5E5E5;
  margin: 0;
  line-height: normal;
}

.btn-cancel::after {
  border: none;
}

/* 提示 */
.tips {
  padding: 30rpx;
  background: #FFFBE6;
  border-radius: 12rpx;
  margin-top: 30rpx;
}

.tip-item {
  font-size: 26rpx;
  color: #8C8C8C;
  margin-bottom: 12rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}
