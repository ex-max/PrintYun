/* pages/user/bindPhone.wxss */

.container {
  padding: 30rpx;
  background: #F5F5F5;
  min-height: 100vh;
}

.tip-card {
  display: flex;
  align-items: flex-start;
  background: #FFFBE6;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.tip-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
  margin-top: 4rpx;
}

.tip-text {
  flex: 1;
  font-size: 26rpx;
  color: #8C8C8C;
  line-height: 1.6;
}

.form-card {
  padding: 40rpx 30rpx;
}

.form-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  text-align: center;
  margin-bottom: 40rpx;
}

.btn-wechat-phone {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #07C160;
  color: #FFFFFF;
  font-size: 32rpx;
  padding: 24rpx;
  border-radius: 12rpx;
  border: none;
  margin: 0;
  width: 100%;
  line-height: normal;
}

.btn-wechat-phone::after {
  border: none;
}

.btn-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
}

.divider-text {
  display: flex;
  align-items: center;
  margin: 40rpx 0;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: #E5E5E5;
}

.divider-text text {
  padding: 0 24rpx;
  font-size: 26rpx;
  color: #999999;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-input {
  width: 100%;
  background: #F5F5F5;
  border: 2rpx solid #E5E5E5;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 32rpx;
  color: #333333;
  box-sizing: border-box;
}

.code-group {
  display: flex;
  gap: 16rpx;
}

.code-input {
  flex: 1;
}

.btn-code {
  width: 200rpx;
  background: #E8F4FD;
  color: #4A90D9;
  font-size: 28rpx;
  padding: 24rpx;
  border-radius: 12rpx;
  border: 1rpx solid #4A90D9;
  margin: 0;
  line-height: normal;
}

.btn-code::after {
  border: none;
}

.btn-code[disabled] {
  background: #F5F5F5;
  color: #CCCCCC;
  border-color: #E5E5E5;
}

.btn-submit {
  background: #4A90D9;
  color: #FFFFFF;
  font-size: 32rpx;
  padding: 24rpx;
  border-radius: 12rpx;
  border: none;
  margin: 0;
  margin-top: 40rpx;
  width: 100%;
  line-height: normal;
}

.btn-submit::after {
  border: none;
}

.btn-submit[disabled] {
  background: #CCCCCC;
}
