/* pages/user/index.wxss */

.container {
  padding: 30rpx;
  padding-bottom: 200rpx;
  background: #F5F5F5;
  min-height: 100vh;
}

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, #4A90D9 0%, #6BA8E8 100%);
  border-radius: 16rpx;
  padding: 50rpx 30rpx;
  margin-bottom: 20rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-right: 30rpx;
}

.user-text {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.user-phone {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 消费统计 */
.stats-card {
  margin-bottom: 20rpx;
}

.stats-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.stats-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.stats-row:first-of-type {
  border-bottom: 1rpx solid #F5F5F5;
}

.stats-item {
  flex: 1;
  text-align: center;
}

.stats-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 26rpx;
  color: #999999;
}

.stats-divider {
  width: 1rpx;
  height: 60rpx;
  background: #E5E5E5;
}

/* 菜单卡片 */
.menu-card {
  margin-bottom: 20rpx;
  padding: 0;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 24rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
}

.menu-desc {
  font-size: 24rpx;
  color: #999999;
  margin-right: 16rpx;
}

.menu-arrow {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.5;
}

/* 退出登录 */
.logout-section {
  margin-top: 40rpx;
  padding: 0 20rpx;
}

.btn-logout {
  background: #FFFFFF;
  color: #FF4D4F;
  font-size: 32rpx;
  padding: 24rpx;
  border-radius: 12rpx;
  border: 1rpx solid #FF4D4F;
  margin: 0;
  width: 100%;
  line-height: normal;
}

.btn-logout::after {
  border: none;
}

/* 版本信息 */
.version-info {
  text-align: center;
  font-size: 24rpx;
  color: #CCCCCC;
  margin-top: 40rpx;
}
