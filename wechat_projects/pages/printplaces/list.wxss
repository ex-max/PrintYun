/* pages/printplaces/list.wxss */

.container {
  padding: 30rpx;
  background: #F5F5F5;
  min-height: 100vh;
}

.place-list {
  
}

.place-card {
  margin-bottom: 20rpx;
}

.place-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.place-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 12rpx;
}

.place-name {
  flex: 1;
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
}

.place-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
}

.place-status.open {
  background: #F6FFED;
  color: #52C41A;
}

.place-status.closed {
  background: #FFF1F0;
  color: #FF4D4F;
}

.place-info {
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  padding: 12rpx 0;
  font-size: 28rpx;
}

.info-label {
  color: #999999;
  width: 140rpx;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  color: #666666;
}

.phone-link {
  color: #4A90D9;
  text-decoration: underline;
}

.place-actions {
  display: flex;
  gap: 20rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #E5E5E5;
}

.btn-nav,
.btn-print {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  margin: 0;
  line-height: normal;
}

.btn-nav {
  background: #FFFFFF;
  color: #4A90D9;
  border: 1rpx solid #4A90D9;
}

.btn-print {
  background: #4A90D9;
  color: #FFFFFF;
  border: none;
}

.btn-nav::after,
.btn-print::after {
  border: none;
}

.action-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 8rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 60rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}
