<!--pages/order/list.wxml-->
<view class="container">
  <!-- Tab 标签 -->
  <view class="tabs">
    <view class="tab-item {{currentTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">
      全部
    </view>
    <view class="tab-item {{currentTab === '0' ? 'active' : ''}}" bindtap="switchTab" data-tab="0">
      待支付
    </view>
    <view class="tab-item {{currentTab === '1' ? 'active' : ''}}" bindtap="switchTab" data-tab="1">
      已支付
    </view>
    <view class="tab-item {{currentTab === '3' ? 'active' : ''}}" bindtap="switchTab" data-tab="3">
      已完成
    </view>
    <view class="tab-item {{currentTab === '-2' ? 'active' : ''}}" bindtap="switchTab" data-tab="-2">
      已取消
    </view>
  </view>

  <!-- 订单列表 -->
  <view class="order-list" wx:if="{{orders.length > 0}}">
    <view class="order-card card" wx:for="{{orders}}" wx:key="tradeNumber" bindtap="goToDetail" data-tradenum="{{item.tradeNumber}}">
      <!-- 订单头部 -->
      <view class="order-header">
        <view class="order-info">
          <view class="file-name">{{item.fileName}}</view>
          <view class="order-meta">{{item.printPlaceName}} · {{item.colorText}} · {{item.printWayText}}</view>
        </view>
        <view class="order-status {{item.statusClass}}">{{item.statusText}}</view>
      </view>
      
      <!-- 订单内容 -->
      <view class="order-content">
        <view class="order-detail">
          <text>{{item.copies}}份 · {{item.pages}}页</text>
        </view>
        <view class="order-amount">
          <text class="amount-label">¥</text>
          <text class="amount-value">{{item.amount}}</text>
        </view>
      </view>
      
      <!-- 订单底部 -->
      <view class="order-footer">
        <view class="order-number">订单号：{{item.tradeNumber}}</view>
        <view class="order-time">{{item.createdAt}}</view>
      </view>
      
      <!-- 操作按钮 -->
      <view class="order-actions" wx:if="{{item.status === 0 || item.status === 3}}">
        <button class="btn-action btn-cancel" wx:if="{{item.status === 0}}" catchtap="cancelOrder" data-tradenum="{{item.tradeNumber}}">
          取消订单
        </button>
        <button class="btn-action btn-pay" wx:if="{{item.status === 0}}" catchtap="goToPay" data-tradenum="{{item.tradeNumber}}" data-amount="{{item.amount}}">
          去支付
        </button>
        <button class="btn-action btn-reprint" wx:if="{{item.status === 3}}" catchtap="reprintOrder" data-tradenum="{{item.tradeNumber}}">
          再次打印
        </button>
      </view>
    </view>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{hasMore && orders.length > 0}}">
    <view wx:if="{{loading}}" class="loading-text">加载中...</view>
    <view wx:else bindtap="loadMore">加载更多</view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && orders.length === 0}}">
    <image class="empty-icon" src="/assets/icons/empty-order.png"></image>
    <view class="empty-text">暂无订单</view>
    <button class="btn-create" bindtap="goToUpload">去下单</button>
  </view>
</view>
