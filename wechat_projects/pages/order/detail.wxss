/* pages/order/detail.wxss */

.container {
  padding: 30rpx;
  padding-bottom: 200rpx;
  background: #F5F5F5;
  min-height: 100vh;
}

/* 状态卡片 */
.status-card {
  text-align: center;
  padding: 50rpx 30rpx;
  margin-bottom: 20rpx;
}

.status-icon-wrap {
  margin-bottom: 24rpx;
}

.status-icon {
  width: 120rpx;
  height: 120rpx;
}

.status-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 12rpx;
}

.status-hint {
  font-size: 28rpx;
  color: #999999;
}

/* 信息卡片 */
.info-card,
.place-card {
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #E5E5E5;
}

.info-list {
  
}

.info-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  font-size: 28rpx;
}

.info-label {
  color: #999999;
  width: 160rpx;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  color: #333333;
}

.info-value.file-name-value {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 320rpx;
}

.info-value.price {
  color: #FF4D4F;
  font-weight: 600;
}

.info-copy,
.info-preview {
  color: #4A90D9;
  font-size: 26rpx;
  padding: 8rpx 16rpx;
  background: #E8F4FD;
  border-radius: 6rpx;
  margin-left: 12rpx;
}

/* 打印点卡片 */
.place-info {
  margin-bottom: 24rpx;
}

.place-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}

.place-address {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.place-row {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.place-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 12rpx;
}

.place-phone {
  color: #4A90D9;
}

.btn-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #4A90D9;
  color: #FFFFFF;
  font-size: 30rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  border: none;
  margin: 0;
  line-height: normal;
}

.btn-nav::after {
  border: none;
}

.nav-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

/* 操作栏 */
.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  background: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.action-bar button {
  font-size: 30rpx;
  padding: 20rpx 40rpx;
  border-radius: 12rpx;
  margin: 0;
  line-height: normal;
}

.action-bar button::after {
  border: none;
}

.btn-preview {
  background: #FFFFFF;
  color: #4A90D9;
  border: 1rpx solid #4A90D9;
}

.btn-reprint {
  background: #FFFFFF;
  color: #52C41A;
  border: 1rpx solid #52C41A;
}

.btn-cancel {
  background: #FFFFFF;
  color: #999999;
  border: 1rpx solid #E5E5E5;
}

.btn-pay {
  background: #4A90D9;
  color: #FFFFFF;
  border: none;
}
