/* pages/order/list.wxss */

.container {
  background: #F5F5F5;
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
}

/* Tab 标签 */
.tabs {
  display: flex;
  background: #FFFFFF;
  padding: 0 20rpx;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: #666666;
  position: relative;
}

.tab-item.active {
  color: #4A90D9;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: 0;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: #4A90D9;
  border-radius: 3rpx;
}

/* 订单列表 */
.order-list {
  padding: 20rpx;
}

.order-card {
  margin-bottom: 20rpx;
  padding: 0;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.order-info {
  flex: 1;
  min-width: 0;
}

.file-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-meta {
  font-size: 24rpx;
  color: #999999;
}

.order-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  white-space: nowrap;
  margin-left: 16rpx;
}

.status-pending {
  background: #FFF7E6;
  color: #FA8C16;
}

.status-paid {
  background: #E6F7FF;
  color: #1890FF;
}

.status-printing {
  background: #F0F5FF;
  color: #597EF7;
}

.status-completed {
  background: #F6FFED;
  color: #52C41A;
}

.status-cancelled {
  background: #FFF1F0;
  color: #FF4D4F;
}

.order-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
}

.order-detail {
  font-size: 26rpx;
  color: #666666;
}

.order-amount {
  color: #FF4D4F;
}

.amount-label {
  font-size: 24rpx;
}

.amount-value {
  font-size: 36rpx;
  font-weight: 700;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: #FAFAFA;
  border-top: 1rpx solid #F5F5F5;
}

.order-number,
.order-time {
  font-size: 24rpx;
  color: #999999;
}

.order-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  border-top: 1rpx solid #F5F5F5;
}

.btn-action {
  font-size: 26rpx;
  padding: 14rpx 28rpx;
  border-radius: 8rpx;
  margin: 0;
  line-height: normal;
}

.btn-action::after {
  border: none;
}

.btn-cancel {
  background: #FFFFFF;
  color: #666666;
  border: 1rpx solid #E5E5E5;
}

.btn-pay {
  background: #4A90D9;
  color: #FFFFFF;
  border: none;
}

.btn-reprint {
  background: #FFFFFF;
  color: #4A90D9;
  border: 1rpx solid #4A90D9;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx;
  font-size: 26rpx;
  color: #999999;
}

.loading-text {
  color: #4A90D9;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 60rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 30rpx;
}

.btn-create {
  background: #4A90D9;
  color: #FFFFFF;
  font-size: 30rpx;
  padding: 20rpx 60rpx;
  border-radius: 12rpx;
  border: none;
  margin: 0;
  line-height: normal;
}

.btn-create::after {
  border: none;
}
