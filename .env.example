# 复制为 .env 并填入真实值；.env.example 可入仓，.env 不可
SECRET_KEY=please_run_python_secrets_token_hex_32

DATABASE_URL=mysql+pymysql://user:password@localhost:3306/print?charset=utf8mb4
REDISTOGO_URL=redis://:password@localhost:6379

ALIYUN_AK=your_access_key_id
ALIYUN_SK=your_access_key_secret
ALIYUN_SMS_SIGN=your_sms_sign
ALIYUN_SMS_TEMPLATE=SMS_xxxxxxxxx

XORPAY_SECRET=your_xorpay_secret

# 自动打印守护进程
PRINTER_NAME=
SUMATRA_PATH=C:\Program Files\SumatraPDF\SumatraPDF.exe
PRINTER_POLL_SECONDS=3
PRINTER_TIMEOUT_SECONDS=120

FLASK_APP=app
FLASK_ENV=development
FLASK_DEBUG=1
